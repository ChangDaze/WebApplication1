@model IEnumerable<WebApplication1.Models.Product>

@{
    ViewData["Title"] = "Our Products";
}

<h2 class="mb-4">Our Products</h2>

<div class="row row-cols-1 row-cols-md-3 g-4">
    @foreach (var item in Model) {
        <div class="col">
            <div class="card h-100 shadow-sm">
                <!-- Placeholder image if ImageUrl is null -->
                <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "https://via.placeholder.com/300x200?text=No+Image" : item.ImageUrl)" class="card-img-top" alt="@item.Name">
                <div class="card-body">
                    <h5 class="card-title">@item.Name</h5>
                    <p class="card-text text-muted">@item.Description</p>
                    <h6 class="card-subtitle mb-2 text-primary">@item.Price.ToString("C")</h6>
                </div>
                <div class="card-footer bg-white border-top-0">
                    <form asp-controller="Cart" asp-action="AddToCart" method="post">
                        <input type="hidden" name="productId" value="@item.Id" />
                        <input type="hidden" name="quantity" value="1" />
                        <button type="submit" class="btn btn-outline-success w-100">
                            Add to Cart
                        </button>
                    </form>
                </div>
            </div>
        </div>
    }
</div>
