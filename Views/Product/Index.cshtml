@model IEnumerable<WebApplication1.Models.Product>

@{
    ViewData["Title"] = "Our Products";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Our Products</h2>
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-primary">+ Add New Product</a>
    }
</div>

<form asp-controller="Product" asp-action="Index" method="get" class="mb-4">
    <div class="input-group">
        <input type="text" name="search" value="@ViewData["Search"]" class="form-control" placeholder="Search products..." />
        <button type="submit" class="btn btn-outline-primary">Search</button>
        @if (ViewData["Search"] != null)
        {
            <a asp-controller="Product" asp-action="Index" class="btn btn-outline-secondary">Clear</a>
        }
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-info">No products found for "@ViewData["Search"]".</div>
}
else
{
<div class="row row-cols-1 row-cols-md-3 g-4">
    @foreach (var item in Model) {
        <div class="col">
            <div class="card h-100 shadow-sm">
                <!-- Placeholder image if ImageUrl is null -->
                <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "https://via.placeholder.com/300x200?text=No+Image" : item.ImageUrl)" class="card-img-top" alt="@item.Name">
                <div class="card-body">
                    <a asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none text-dark">
                        <h5 class="card-title">@item.Name</h5>
                    </a>
                    <p class="card-text text-muted">@item.Description</p>
                    <h6 class="card-subtitle mb-2 text-primary">@item.Price.ToString("C")</h6>
                </div>
                <div class="card-footer bg-white border-top-0">
                    <form asp-controller="Cart" asp-action="AddToCart" method="post">
                        <input type="hidden" name="productId" value="@item.Id" />
                        <input type="hidden" name="quantity" value="1" />
                        <button type="submit" class="btn btn-outline-success w-100">
                            Add to Cart
                        </button>
                    </form>
                    @if (User.IsInRole("Admin"))
                    {
                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="mt-2"
                              onsubmit="return confirm('Delete this product?');">
                            <button type="submit" class="btn btn-outline-danger btn-sm w-100">Delete</button>
                        </form>
                    }
                </div>
            </div>
        </div>
    }
</div>
}
