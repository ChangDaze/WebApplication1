@model WebApplication1.Models.CheckoutViewModel

@{
    ViewData["Title"] = "Checkout";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <h2 class="mb-4">Checkout</h2>

        @if (!ViewData.ModelState.IsValid && ViewData.ModelState[string.Empty]?.Errors.Count > 0)
        {
            <div class="alert alert-danger" asp-validation-summary="ModelOnly"></div>
        }

        <form asp-controller="Checkout" asp-action="Index" method="post">
            <div class="mb-3">
                <label asp-for="CustomerName" class="form-label"></label>
                <input asp-for="CustomerName" class="form-control" placeholder="Jane Smith" />
                <span asp-validation-for="CustomerName" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" placeholder="jane@example.com" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ShippingAddress" class="form-label"></label>
                <textarea asp-for="ShippingAddress" class="form-control" rows="3" placeholder="123 Main St, City, State, ZIP"></textarea>
                <span asp-validation-for="ShippingAddress" class="text-danger small"></span>
            </div>

            <div class="d-flex justify-content-between mt-4">
                <a asp-controller="Cart" asp-action="Index" class="btn btn-outline-secondary">Back to Cart</a>
                <button type="submit" class="btn btn-success btn-lg px-4">Place Order</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
