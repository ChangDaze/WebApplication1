@model int

@{
    ViewData["Title"] = "Order Confirmed";
}

<div class="row justify-content-center text-center mt-5">
    <div class="col-md-6">
        <div class="alert alert-success py-5 shadow-sm rounded">
            <h1 class="display-4">&#10003;</h1>
            <h2 class="mb-3">Order Confirmed!</h2>
            <p class="fs-5">Thank you for your purchase. Your order number is:</p>
            <p class="display-6 fw-bold">#@Model</p>
        </div>
        <a asp-controller="Product" asp-action="Index" class="btn btn-primary mt-3">Continue Shopping</a>
    </div>
</div>
